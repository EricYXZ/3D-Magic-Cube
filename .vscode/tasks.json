    {
      "label": "clean debug x64",
      "type": "shell",
      "command": "cmd.exe",
      "args": [
        "/d",
        "/s",
        "/c",
        "call \"C:\\Program Files\\Microsoft Visual Studio\\2022\\Community\\Common7\\Tools\\VsDevCmd.bat\" -arch=x64 -host_arch=x64 && msbuild \"${workspaceFolder}\\Pocket Cube.sln\" /t:Clean /p:Configuration=Debug /p:Platform=x64"
      ],
